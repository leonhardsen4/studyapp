<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.leonhardsen.studyapp.controller.LoginController"
           styleClass="auth-root">

    <VBox styleClass="auth-card" maxWidth="380" spacing="0">

        <!-- Cabeçalho -->
        <VBox styleClass="auth-header" spacing="4">
            <Label text="StudyApp" styleClass="auth-app-title"/>
            <Label text="Bem-vindo de volta" styleClass="auth-subtitle"/>
        </VBox>

        <!-- Formulário -->
        <VBox styleClass="auth-form" spacing="16">
            <VBox spacing="6">
                <Label text="E-mail" styleClass="form-label"/>
                <TextField fx:id="tfEmail" promptText="seu@email.com" styleClass="form-input"/>
            </VBox>

            <VBox spacing="6">
                <Label text="Senha" styleClass="form-label"/>
                <PasswordField fx:id="pfSenha" promptText="Sua senha" styleClass="form-input"/>
            </VBox>

            <Label fx:id="labelErro" styleClass="error-label" wrapText="true" managed="false" visible="false"/>

            <Button fx:id="btnEntrar" text="Entrar" onAction="#handleLogin"
                    styleClass="btn-primary" maxWidth="Infinity"/>

            <Separator/>

            <HBox alignment="CENTER" spacing="4">
                <Label text="Não tem conta?" styleClass="auth-link-text"/>
                <Hyperlink text="Cadastre-se" onAction="#handleIrParaCadastro" styleClass="auth-link"/>
            </HBox>

            <HBox alignment="CENTER">
                <Hyperlink text="Esqueceu a senha?" onAction="#handleEsqueceuSenha" styleClass="auth-link-small"/>
            </HBox>
        </VBox>

    </VBox>
</StackPane>
