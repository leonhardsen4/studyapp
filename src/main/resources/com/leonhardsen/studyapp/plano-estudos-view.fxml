<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.leonhardsen.studyapp.controller.PlanoEstudosController"
            styleClass="plano-root">

    <!-- ═══════════════ TOOLBAR ═══════════════ -->
    <top>
        <HBox styleClass="module-toolbar" alignment="CENTER_LEFT" spacing="8">
            <padding><Insets top="7" right="12" bottom="7" left="12"/></padding>
            <Label text="📚 Plano de Estudos" styleClass="module-titulo"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="+ Disciplina" styleClass="btn-action" onAction="#handleNovaDisciplina">
                <tooltip><Tooltip text="Adicionar nova disciplina"/></tooltip>
            </Button>
            <Button fx:id="btnNovoAssunto" text="+ Assunto" styleClass="btn-action"
                    disable="true" onAction="#handleNovoAssunto">
                <tooltip><Tooltip text="Adicionar assunto à disciplina selecionada"/></tooltip>
            </Button>
        </HBox>
    </top>

    <!-- ═══════════════ CONTEÚDO ═══════════════ -->
    <center>
        <SplitPane fx:id="splitPlano" dividerPositions="0.28" styleClass="plano-split">

            <!-- ── Painel esquerdo: busca + lista de disciplinas + toggle arquivadas ── -->
            <BorderPane styleClass="plano-sidebar-panel" minWidth="200">

                <!-- Barra de pesquisa (fixa no topo) -->
                <top>
                    <HBox styleClass="plano-busca-bar" alignment="CENTER_LEFT" spacing="4">
                        <padding><Insets top="8" right="8" bottom="8" left="8"/></padding>
                        <TextField fx:id="campoBusca" promptText="🔍 Pesquisar…"
                                   styleClass="plano-busca-field" HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnLimparBusca" text="✕" styleClass="btn-action"
                                visible="false" managed="false" onAction="#handleLimparBusca">
                            <tooltip><Tooltip text="Limpar pesquisa"/></tooltip>
                        </Button>
                    </HBox>
                </top>

                <!-- Lista de disciplinas (scrollável) -->
                <center>
                    <ScrollPane fitToWidth="true" styleClass="plano-sidebar">
                        <VBox fx:id="listaDisciplinas" spacing="6" styleClass="plano-disc-lista">
                            <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>
                        </VBox>
                    </ScrollPane>
                </center>

                <!-- Botão de arquivadas (fixo no rodapé) -->
                <bottom>
                    <HBox styleClass="plano-sidebar-footer">
                        <padding><Insets top="6" right="8" bottom="6" left="8"/></padding>
                        <Button fx:id="btnVerArquivadas" text="📦 Ver arquivadas"
                                styleClass="plano-arquivo-toggle" maxWidth="Infinity"
                                onAction="#handleToggleArquivadas" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </bottom>

            </BorderPane>

            <!-- ── Painel direito: assuntos da disciplina selecionada ── -->
            <BorderPane styleClass="plano-content">

                <!-- Cabeçalho da disciplina selecionada -->
                <top>
                    <VBox fx:id="headerAssuntos" styleClass="plano-header" visible="false" managed="false">
                        <padding><Insets top="14" right="16" bottom="12" left="16"/></padding>
                        <Label fx:id="lblNomeDisciplina" styleClass="plano-disc-titulo"/>
                        <Label fx:id="lblResumoDisc"    styleClass="plano-disc-resumo"/>
                    </VBox>
                </top>

                <!-- Estado vazio / lista de assuntos -->
                <center>
                    <StackPane>
                        <VBox fx:id="painelVazio" alignment="CENTER" spacing="12"
                              styleClass="plano-vazio" visible="true" managed="true">
                            <Label text="📚" style="-fx-font-size: 48px;"/>
                            <Label text="Selecione uma disciplina" styleClass="plano-vazio-titulo"/>
                            <Label text="ou crie uma nova usando '+ Disciplina'" styleClass="plano-vazio-hint"/>
                        </VBox>

                        <ScrollPane fx:id="scrollAssuntos" fitToWidth="true"
                                    styleClass="plano-assuntos-scroll" visible="false" managed="false">
                            <VBox fx:id="listaAssuntos" spacing="10" styleClass="plano-assuntos-lista">
                                <padding><Insets top="14" right="16" bottom="16" left="16"/></padding>
                            </VBox>
                        </ScrollPane>
                    </StackPane>
                </center>

            </BorderPane>
        </SplitPane>
    </center>

</BorderPane>
