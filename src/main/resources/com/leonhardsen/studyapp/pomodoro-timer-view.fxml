<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!--
    Timer Pomodoro — painel incorporado ao Plano de Estudos.
    O BorderPane externo (container) serve de âncora para o destacar/reintegrar:
    quando destacado, o BorderPane interno (raiz) migra para uma janela separada
    e o container exibe um placeholder.
-->
<BorderPane fx:id="container"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.leonhardsen.studyapp.controller.PomodoroTimerController"
            minWidth="240">
    <center>

        <!-- raiz = bloco que migra para a janela destacada -->
        <BorderPane fx:id="raiz" styleClass="plano-timer-raiz">

            <!-- ══════════ CABEÇALHO ══════════ -->
            <top>
                <HBox styleClass="module-toolbar" alignment="CENTER_LEFT" spacing="6">
                    <padding><Insets top="7" right="8" bottom="7" left="10"/></padding>
                    <Label text="🍅" style="-fx-font-size: 15px;"/>
                    <Label fx:id="lblEstudando" text="Selecione um assunto"
                           styleClass="plano-timer-estudando" maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                    <Button text="⚙" onAction="#handleConfigurar" styleClass="btn-action">
                        <tooltip><Tooltip text="Ajustar durações das sessões"/></tooltip>
                    </Button>
                    <Button fx:id="btnDetachar" text="↗" onAction="#handleDetachar" styleClass="btn-action">
                        <tooltip><Tooltip text="Abrir em janela separada"/></tooltip>
                    </Button>
                    <Button text="✕" onAction="#handleEncerrar" styleClass="btn-action">
                        <tooltip><Tooltip text="Encerrar sessão e fechar painel"/></tooltip>
                    </Button>
                </HBox>
            </top>

            <!-- ══════════ CONTEÚDO DO TIMER ══════════ -->
            <center>
                <VBox styleClass="pomo-timer-panel" alignment="CENTER" spacing="18">
                    <padding><Insets top="16" right="12" bottom="16" left="12"/></padding>

                    <!-- Seletor de fase -->
                    <HBox alignment="CENTER" spacing="4" styleClass="pomo-fases-container">
                        <Button fx:id="btnFoco" text="Foco" onAction="#handleFaseFoco"
                                styleClass="pomo-fase-btn">
                            <tooltip><Tooltip text="Sessão de foco"/></tooltip>
                        </Button>
                        <Button fx:id="btnPausaCurta" text="Pausa Curta" onAction="#handleFasePausaCurta"
                                styleClass="pomo-fase-btn">
                            <tooltip><Tooltip text="Pausa curta entre sessões"/></tooltip>
                        </Button>
                        <Button fx:id="btnPausaLonga" text="Pausa Longa" onAction="#handleFasePausaLonga"
                                styleClass="pomo-fase-btn">
                            <tooltip><Tooltip text="Pausa longa após 4 sessões"/></tooltip>
                        </Button>
                    </HBox>

                    <!-- Display principal do timer -->
                    <Label fx:id="lblTimer" text="25:00" styleClass="pomo-timer"/>

                    <!-- Indicador de ciclo (🍅🍅○○) -->
                    <HBox fx:id="hboxCiclo" alignment="CENTER" spacing="10"/>

                    <!-- Controles de execução -->
                    <HBox alignment="CENTER" spacing="14">
                        <Button fx:id="btnReiniciar" text="↺" onAction="#handleReiniciar"
                                styleClass="btn-action" prefWidth="40" prefHeight="40">
                            <tooltip><Tooltip text="Reiniciar fase atual"/></tooltip>
                        </Button>
                        <Button fx:id="btnIniciarPausar" text="▶  Iniciar" onAction="#handleIniciarPausar"
                                styleClass="pomo-btn-principal"/>
                        <Button fx:id="btnPular" text="⏭" onAction="#handlePular"
                                styleClass="btn-action" prefWidth="40" prefHeight="40">
                            <tooltip><Tooltip text="Pular para a próxima fase"/></tooltip>
                        </Button>
                    </HBox>

                    <!-- Estatísticas do dia -->
                    <VBox styleClass="pomodoro-stats" spacing="4" alignment="CENTER">
                        <Label text="HOJE" styleClass="pomodoro-stats-titulo"/>
                        <HBox spacing="10" alignment="CENTER">
                            <Label fx:id="lblSessoesHoje" text="0 sessões" styleClass="pomodoro-stats-valor"/>
                            <Label text="·" styleClass="pomodoro-stats-sep"/>
                            <Label fx:id="lblTempoHoje" text="0 min" styleClass="pomodoro-stats-valor"/>
                        </HBox>
                    </VBox>

                </VBox>
            </center>

        </BorderPane>

    </center>
</BorderPane>
