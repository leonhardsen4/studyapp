<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="raiz"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.leonhardsen.studyapp.controller.BlocoNotasController"
      styleClass="bloconotas-root">

    <!-- ── Toolbar ── -->
    <HBox styleClass="module-toolbar" alignment="CENTER_LEFT" spacing="8">
        <padding><Insets top="7" right="12" bottom="7" left="12"/></padding>
        <Label text="📝 Bloco de Notas" styleClass="module-titulo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblStatus" styleClass="status-label"/>
        <Button text="🗑 Limpar" styleClass="btn-action" onAction="#handleLimpar">
            <tooltip><Tooltip text="Apagar todo o conteúdo do bloco de notas"/></tooltip>
        </Button>
        <Button text="💾 Salvar .txt" styleClass="btn-action" onAction="#handleSalvarTxt">
            <tooltip><Tooltip text="Exportar o conteúdo como arquivo .txt"/></tooltip>
        </Button>
        <Button fx:id="btnDetachar" text="↗ Destacar" styleClass="btn-action" onAction="#handleDetachar">
            <tooltip><Tooltip text="Abrir em janela separada sempre no topo"/></tooltip>
        </Button>
    </HBox>

    <Separator/>

    <TextArea fx:id="textArea"
              styleClass="bloconotas-textarea"
              wrapText="true"
              VBox.vgrow="ALWAYS"/>

</VBox>
